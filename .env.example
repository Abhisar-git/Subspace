# Apollo.io API Key
APOLLO_API_KEY=your_apollo_api_key_here

# Prospeo API Key
PROSPEO_API_KEY=your_prospeo_api_key_here

# Resend API Key
RESEND_API_KEY=your_resend_api_key_here

# Sender Email Address (e.g., onboarding@resend.dev or verified domain sender)
SENDER_EMAIL=onboarding@resend.dev

# Recipient Email Override (Optional)
# Set this during testing to redirect all outbound cold-outreach emails to your own inbox
RECIPIENT_OVERRIDE=
